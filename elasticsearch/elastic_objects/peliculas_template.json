{
  "name": "peliculas_csv_template",
  "index_patterns": ["peliculas-csv*"],
  "template": {
    "settings": {
      "number_of_shards": 1,
      "number_of_replicas": 2,
      "analysis": {
        "analyzer": {
          "analizador_pro": {
            "type": "custom",
            "tokenizer": "standard",
            "filter": ["lowercase", "asciifolding"]
          }
        }
      }
    },
    "mappings": {
      "dynamic": "strict",
      "properties": {
        "id": { "type": "keyword" },
        "title": { "type": "text", "analyzer": "analizador_pro" },
        "overview": { "type": "text", "analyzer": "spanish" },
        "vote_average": { "type": "float" },
        "release_date": { "type": "date" },
        "genre_names": { "type": "keyword" },
        "cast_names": { "type": "text", "analyzer": "analizador_pro", "fields": { "keyword": { "type": "keyword" } } },
        "poster_url": { "type": "keyword", "index": false }
      }
    }
  }
}